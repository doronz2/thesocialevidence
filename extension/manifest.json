{
  "manifest_version": 2,
  "version": "1",
  "name": "The Social Evidence",
  "description": "The Social Evidence.",
  "author": "Tim Zadorozhny",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}
